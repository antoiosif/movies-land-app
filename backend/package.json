{
  "name": "movies-land",
  "version": "1.0.0",
  "description": "A movie search app that allows users to save movies as favorites. It is integrated with OMDb API for movie title search, and provides a CRUD API to manage users and their favorites.",
  "keywords": [
    "users",
    "favorites",
    "CRUD"
  ],
  "homepage": "https://github.com/antoiosif/movies-land-app#readme",
  "bugs": {
    "url": "https://github.com/antoiosif/movies-land-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antoiosif/movies-land-app.git"
  },
  "license": "ISC",
  "author": "Tania Iosif",
  "type": "commonjs",
  "main": "app.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test jest --testTimeout=10000",
    "start": "node --env-file=.env server.js",
    "dev": "node --env-file=.env --watch server.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-mongodb": "^7.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "collectCoverage": true,
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/logs"
    ],
    "setupFiles": [
      "dotenv/config"
    ]
  }
}
